# Database - same MySQL as Laravel Deprixa Plus
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=deprixa_plus
DB_USERNAME=root
DB_PASSWORD=

# Redis - for rate limiting and caching
REDIS_URL=redis://127.0.0.1:6379/1

# API Gateway
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=2

# Laravel internal (required for rates/inventory proxy)
LARAVEL_INTERNAL_URL=http://127.0.0.1:8000
LARAVEL_INTERNAL_TIMEOUT=10

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Security
LOG_PAYLOAD_HASH_ONLY=true
# PRODUCTION: Keep False. Set to True only in local dev to enable /docs and /redoc Swagger UI.
ENABLE_API_DOCS=false
