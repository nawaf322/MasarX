APP_NAME="Deprixa Plus"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://yourdomain.com
APP_EDITION=Plus

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

MAIL_MAILER=smtp
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Moyasar (Saudi Payment Gateway) ─────────────────────────────
MOYASAR_PUBLISHABLE_KEY=pk_test_xxxx
MOYASAR_SECRET_KEY=sk_test_xxxx
MOYASAR_WEBHOOK_SECRET=

# ─── Saudi Carriers ──────────────────────────────────────────────
ARAMEX_ENABLED=false
ARAMEX_USERNAME=
ARAMEX_PASSWORD=
ARAMEX_VERSION=v1.0
ARAMEX_PIN=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
ARAMEX_ACCOUNT_ENTITY=RUH
ARAMEX_ACCOUNT_COUNTRY_CODE=SA
ARAMEX_TEST_MODE=true

SMSA_ENABLED=false
SMSA_PASS_KEY=
SMSA_SENDER_CODE=
SMSA_FLAT_RATE=25.00
SMSA_TEST_MODE=true

DHL_ENABLED=false
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_TEST_MODE=true
